# Comment System Configuration

# Admin token for comment moderation
# Generate a secure random string for production
ADMIN_TOKEN=your-secret-admin-token-here

# Upstash Redis (required for persistent storage in production)
# Get these from https://upstash.com after creating a Redis database
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# Optional: Rate limiting (comments per hour per IP)
MAX_COMMENTS_PER_HOUR=3

# Optional: Maximum comment length
COMMENT_MAX_LENGTH=500
